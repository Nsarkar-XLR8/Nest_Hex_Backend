NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/nest_hex
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=nest-hex-orders
S3_FORCE_PATH_STYLE=false
IDEMPOTENCY_TTL_SECONDS=3600
JWT_SECRET=change-me-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TTL_SECONDS=1209600
OTP_TTL_SECONDS=300
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_LOCK_TTL_SECONDS=900
OTP_ATTEMPTS_LIMIT=5
OTP_LOCK_TTL_SECONDS=900
METRICS_PATH=/metrics
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
SERVICE_NAME=nest-hex-backend
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user
SMTP_PASS=your-pass
SMTP_FROM="Nest Hex <noreply@yourdomain.com>"
SCALAR_USERNAME=docs-user
SCALAR_PASSWORD=docs-password
OPENAPI_JSON_PATH=/api/v1/openapi.json
API_REFERENCE_PATH=/api/v1/reference
